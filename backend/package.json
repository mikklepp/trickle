{
  "name": "trickle-backend",
  "version": "1.1.0",
  "description": "Trickle backend Lambda functions",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc && cp package.json package-lock.json dist/ && npm install --omit=dev --prefix dist/",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1037.0",
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/client-scheduler": "^3.1037.0",
    "@aws-sdk/client-sesv2": "^3.1037.0",
    "@aws-sdk/client-ssm": "^3.1037.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "jsonwebtoken": "^9.0.3",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.156",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
