{
  "name": "trickle-frontend",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -b --noEmit",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "watch": "npm-run-all --parallel tsc:watch vite:watch",
    "tsc:watch": "tsc -b --watch",
    "vite:watch": "vite build --watch"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.3",
    "react-quill-new": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.4"
  }
}
